# ── MedLearn API — PRODUCTION Environment ──────────────────────────────────
# Copy this to your Railway / Render environment variables dashboard
# DO NOT commit this file with real values to git

# ── Database (Neon PostgreSQL — free tier handles 50K users easily) ─────────
DATABASE_PROVIDER="postgresql"
DATABASE_URL="postgresql://USER:PASSWORD@HOST/medlearn?sslmode=require"
# Get this from: https://neon.tech → New Project → Connection String

# ── Auth ────────────────────────────────────────────────────────────────────
NODE_ENV="production"
PORT=4000
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME_64_CHAR_HEX_STRING"
JWT_REFRESH_SECRET="CHANGE_ME_ANOTHER_64_CHAR_HEX_STRING"

# ── AI ──────────────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/apikey (free)
GEMINI_API_KEY="AIzaSy..."

# ── CORS ────────────────────────────────────────────────────────────────────
# Your production domain once deployed
ALLOWED_ORIGIN="https://medlearn.yourdomain.com"
