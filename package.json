{
  "name": "medlearn-ai",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @medlearn/api\" \"npm run dev -w @medlearn/web\"",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test -w @medlearn/api",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
